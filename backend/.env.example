# Backend Server Configuration
BACKEND_PORT=5000
NODE_ENV=development

# Authentication & Session (Backend-driven, all credentials server-side only)
AUTH_JWT_SECRET=your-super-secret-jwt-key-min-32-chars-recommended
AUTH_COOKIE_NAME=flowsense_session
SESSION_TTL_DAYS=7

# AI Providers (Server-side only - add your API keys here)
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Firebase (server-side only, for analytics/verification)
# FIREBASE_API_KEY=your-api-key
# FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# FIREBASE_APP_ID=your-app-id
# FIREBASE_MEASUREMENT_ID=your-measurement-id

