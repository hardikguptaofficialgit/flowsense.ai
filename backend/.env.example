# Backend server
BACKEND_PORT=5000

# AI providers (server-side only)
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Authentication/session settings (if backend auth/session is enabled)
AUTH_JWT_SECRET=
AUTH_COOKIE_NAME=flowsense_session

# Firebase server-side config placeholders (optional)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase web/app metadata for backend-owned configuration flows (optional)
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MEASUREMENT_ID=
