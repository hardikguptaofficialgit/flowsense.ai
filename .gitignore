# ============================================================================
# DEPENDENCIES
# ============================================================================
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================================================
# ENVIRONMENT VARIABLES (CRITICAL - NEVER COMMIT SECRETS)
# ============================================================================
# Frontend & Backend environment files (contain API keys, secrets, credentials)
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# Backend-specific (always exclude actual env files)
backend/.env
backend/.env.local
backend/.env.*.local

# Allow examples/templates only (no actual secrets)
!.env.example
!*.env.example
!backend/.env.example

# ============================================================================
# BUILD & DIST
# ============================================================================
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
coverage/
.nyc_output/

# ============================================================================
# IDE & EDITOR
# ============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.idea_modules/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project
.eclipse
.project
.pydevproject
.settings
*.iml
*.iws
.classpath

# ============================================================================
# OS & SYSTEM FILES
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.bak
*.tmp
*.temp
*.swp
.AppleDouble
.LSOverride

# ============================================================================
# RUNTIME & TEMPORARY
# ============================================================================
*.local
*.pid
*.seed
*.pid.lock
.cache/
tmp/
temp/
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# ============================================================================
# DATABASE & DATA
# ============================================================================
*.db
*.sqlite
*.sqlite3
.data/
database.json
local.db

# ============================================================================
# CREDENTIALS & SECRETS (EXTRA SAFETY)
# ============================================================================
# Firebase credentials
*firebase-credentials.json
*serviceAccountKey.json
firebase-config.private.js

# API Keys & tokens (if accidentally created as files)
*.key
*.pem
*.pub
*.private
secrets/
.secrets/
*.secret

# ============================================================================
# TESTING
# ============================================================================
.coverage
coverage.html
.jest_cache/

# ============================================================================
# GENERATED FILES
# ============================================================================
.cache/
.parcel-cache/
dist/
out/
.env
.env
.env
backend/.env
